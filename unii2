#include <iostream>
using namespace std;

bool isPrime(int n){
    if(n < 2)
        return false;

    for(int i = 2; i < n; i++){
        if(n % i == 0)
            return false;
    }
    return true;
}

int main(){
    int n, x;
    int count = 0;

    cout << "Tedad adad: ";
    cin >> n;

    for(int i = 1; i <= n; i++){
        cout << "Adad ra vared kon: ";
        cin >> x;

        if(isPrime(x)){
            cout << "Aval\n";
            count++;
        }
        else{
            cout << "Morakkab\n";
        }
    }

    cout << "Tedad adad haye aval: " << count;
}

