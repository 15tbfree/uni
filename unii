#include <iostream>
using namespace std;

void checkPrime(int n){
    bool f = true;

    if(n < 2)
        f = false;

    for(int i = 2; i < n; i++){
        if(n % i == 0){
            f = false;
            break;
        }
    }

    if(f)
        cout << "Aval\n";
    else
        cout << "Morakkab\n";
}

int main(){
    int n, x;

    cout << "Tedad adad: ";
    cin >> n;

    for(int i = 1; i <= n; i++){
        cin >> x;
        checkPrime(x);
    }
}

